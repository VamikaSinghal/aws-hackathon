# Server
PORT=8787
HOST=127.0.0.1
ADAPTIVE_HEALTH_STATE_PATH=./data/adaptive-health-state.json

# Nexla: normalized health data layer
# Agent API base from the hackathon's Nexla Agent CLI docs (nexla.com/agent-cli).
NEXLA_API_URL=https://dev-api-express-code.nexla.com/
# Service key from express.dev -> mints a fresh bearer token per nexla-cli login.
NEXLA_SERVICE_KEY=
# Optional static fallback bearer token (used if nexla-cli isn't on PATH, e.g. Lambda).
NEXLA_TOKEN=
# hosted_url returned by `nexla-cli sources create --connector webhook` (includes its own api_key).
NEXLA_WEBHOOK_URL=
# The nexset id that materializes after the first webhook payload (see source's source_nexset_id).
NEXLA_NEXSET_ID=

# Zero.xyz: capability marketplace (search -> pay -> call -> review), not a fixed API.
# Requires `zero auth login` (or `zero auth agent register`) once on this machine; there is
# no API key to set here. Leave ZERO_LIVE unset/false to stay on free deterministic fallback.
ZERO_LIVE=false
# ZERO_MAX_PAY=0.10             # optional: per-call spend cap in USDC (default 0.10)
# ZERO_SEARCH_QUERY=openai chat completions json
# ZERO_MODEL=gpt-4o-mini
# ZERO_OPENROUTER_MODEL=openai/gpt-4o-mini
# ZERO_BLOCKED_SLUGS=groq-chat-0362cf4f

# Pomerium: secure action bridge. Self-hosted, pure mutual TLS - no IdP, no API key
# (open-source Pomerium has no service-account feature; that's Enterprise-only).
# Run infra/pomerium/generate-certs.sh, then `docker compose up -d` in infra/pomerium/.
POMERIUM_ACTION_URL=https://adaptive-health-actions.localhost.pomerium.io:8443/execute
POMERIUM_CLIENT_CERT_PATH=./infra/pomerium/certs/client.crt
POMERIUM_CLIENT_KEY_PATH=./infra/pomerium/certs/client.key
POMERIUM_CA_PATH=./infra/pomerium/certs/ca.crt

# AWS: production orchestration path. Leave AWS_DYNAMODB_TABLE unset for local dev (falls back
# to the local JSON file) - only set it to intentionally point local runs at a real deployed
# table (the CloudFormation-generated name, not a made-up one; see infra/aws/template.yaml).
AWS_REGION=us-west-2
AWS_DYNAMODB_TABLE=

# Akash: deployment path
AKASH_IMAGE=vamikasinghal/adaptive-health:v3
